{
  "BunkFy": {
    "CountryPolicies": {
      "PackDirectory": "../../eng/country-policies/development",
      "Allowlist": [
        {
          "OperatingCountryCode": "GB",
          "PolicyId": "development-hostel-example",
          "PolicyVersion": 1,
          "ContentSha256": "c318d3f280989994c612dcc35a0f5b5ee4449016820ad1fdc30f8ce105d9f71d",
          "LaunchStatus": "Engineering"
        }
      ]
    },
    "WorkspaceAdmission": {
      "AccountRegistration": "Public",
      "WorkspaceCreation": "SelfService",
      "RequireVerifiedEmailForWorkspaceCreation": false
    }
  },
  "ConnectionStrings": {
    "SqlServer": "Server=localhost,1433;Database=BunkFy;User Id=sa;Password=Pass@word1;TrustServerCertificate=True",
    "PostgreSql": "Host=localhost;Port=5432;Database=bunkfy;Username=postgres;Password=postgres",
    "nats": "nats://localhost:4222"
  },
  "DataProtection": {
    "RequirePersistentKeys": true,
    "KeyRingPath": ".data/data-protection-keys",
    "ApplicationName": "bunkfy"
  },
  "FileManagement": {
    "AllowedContentTypes": [
      "application/json",
      "message/rfc822"
    ],
    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "bunkfy-files",
      "UseSsl": false,
      "CreateBucketIfMissing": true
    }
  },
  "Auth": {
    "RefreshTokens": {
      "Pepper": "local-development-refresh-token-pepper-change-me-00000000000000000000"
    },
    "Jwt": {
      "SigningKey": "local-development-signing-key-change-me-00000000000000000000"
    }
  },
  "Observability": {
    "Prometheus": {
      "Enabled": true,
      "EndpointPath": "/metrics"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
